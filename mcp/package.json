{
  "name": "trivia-engine-mcp",
  "version": "1.0.0",
  "description": "MCP server for Trivia Engine API - provides comprehensive access to trivia questions, user management, and API key operations",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "docker:build": "docker build -t trivia-engine-mcp:latest .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t trivia-engine-mcp:dev .",
    "docker:run": "docker run --rm -it --env-file .env trivia-engine-mcp:latest",
    "docker:run:dev": "docker-compose up mcp-server-dev",
    "docker:compose:up": "docker-compose up mcp-server",
    "docker:compose:down": "docker-compose down"
  },
  "keywords": ["mcp", "trivia", "api", "model-context-protocol"],
  "author": "Trivia Engine Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
