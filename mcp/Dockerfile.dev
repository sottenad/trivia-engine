# Development Dockerfile with hot reload support
FROM node:20-alpine

# Install development tools
RUN apk add --no-cache bash

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm ci

# TypeScript will be compiled on the fly by tsc --watch
# Source files will be mounted as volumes

# Default command runs TypeScript in watch mode
CMD ["npm", "run", "dev"]