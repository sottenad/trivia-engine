# Trivia Engine Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=3003

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/trivia_engine
DB_CONNECTION_LIMIT=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=90d

# API Key Configuration
API_KEY_SALT_ROUNDS=32
DEFAULT_RATE_LIMIT_REQUESTS=100
DEFAULT_RATE_LIMIT_WINDOW=3600

# Security Configuration
BCRYPT_ROUNDS=10
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
TRUSTED_PROXIES=127.0.0.1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Cache Configuration (optional)
CACHE_ENABLED=false
CACHE_TTL=3600
# REDIS_URL=redis://localhost:6379

# Rate Limiting
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_MAX=1000
GLOBAL_RATE_LIMIT_WINDOW_MS=900000

# Marketing Site Configuration (in marketing/.env.local)
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
# NEXT_PUBLIC_API_KEY=your-api-key-here

# MCP Server Configuration (in mcp/.env)
# TRIVIA_API_BASE_URL=http://localhost:3003/api/v1
# TRIVIA_API_KEY=your-api-key-here