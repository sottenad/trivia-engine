# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
app/node_modules/
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.sample

# Environment files - NEVER commit these
app/.env
app/.env.local
app/.env.production
marketing/.env
marketing/.env.local
marketing/.env.production
mcp/.env
mcp/.env.local

# Generated credentials files
credentials.*.txt
*credentials*.txt

# Backup files
*.backup
*.backup.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/dumps
